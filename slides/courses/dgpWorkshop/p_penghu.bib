  author = {Zhong, Jinping and Mo, Yilan and Zhang, Junyi and Liu, Panpan and Luo, Xianfei and Liu, Lixiang and Ding, Ruofei and Huang, Jingxiu and Zheng, Yunxiang},
  date = {2025-08-08},
