@article{Condon2015,
  title = {Voice {{Lessons}}: {{Rethinking}} the {{Relationship Between Education}} and {{Political Participation}}},
  shorttitle = {Voice {{Lessons}}},
  author = {Condon, Meghan},
  date = {2015-12-01},
  journaltitle = {Political Behavior},
  shortjournal = {Polit Behav},
  volume = {37},
  number = {4},
  pages = {819--843},
  issn = {1573-6687},
  doi = {10.1007/s11109-015-9301-0},
  url = {https://doi.org/10.1007/s11109-015-9301-0},
  urldate = {2025-09-02},
  abstract = {The association between education and political participation is one of the strongest and most reliable in American politics, but it is poorly understood. Whether human capital acquired through education affects participation remains unknown. Most studies of this question restrict measurement of human capital to years of schooling (attainment) or civics knowledge. But attainment is a weak instrument for human capital, which varies considerably within attainment levels. And skills beyond civics—particularly verbal communication skills—are politically important. With data from the National Education Longitudinal Study, I examine the relationship between verbal skills acquired in school during adolescence and participation later in life. I find a strong positive effect, showing that when young people learn to use their voices in school, they are more likely to speak up as participatory adults. The findings reveal an important mechanism by which education affects democratic life, call for a broadening of the empirical treatment of education in political science, and suggest an answer to the puzzle of participation.},
  keywords = {Civic engagement,Education,Longitudinal data,Voter turnout,Youth turnout},
  file = {/Users/xinyiye/Zotero/storage/3N3ZVPLT/Condon - 2015 - Voice Lessons Rethinking the Relationship Between Education and Political Participation.pdf}
}

@article{Costa-FontEtAl2024,
  title = {Long-Lasting Effects of Indoctrination in School: {{Evidence}} from the {{People}}’s {{Republic}} of {{Poland}}},
  shorttitle = {Long-Lasting Effects of Indoctrination in School},
  author = {Costa-Font, Joan and García-Hombrados, Jorge and Nicińska, Anna},
  date = {2024-01-01},
  journaltitle = {European Economic Review},
  shortjournal = {European Economic Review},
  volume = {161},
  pages = {104641},
  issn = {0014-2921},
  doi = {10.1016/j.euroecorev.2023.104641},
  url = {https://www.sciencedirect.com/science/article/pii/S0014292123002696},
  urldate = {2025-09-10},
  abstract = {This paper studies the effect of communist indoctrination in school on labour force participation and human capital investments. Specifically, we evaluate the impact of a reform in Poland that revoked political indoctrination in school in the mid-1950s, while leaving the rest of the curriculum unchanged. To overcome endogeneity concerns, we exploit cut-off birth dates for school enrolment that exhibit variation in the level of exposure to the reform. We find that a reduction in school indoctrination increased the probability of finishing secondary and tertiary education, and expanded labour force participation about 50 years down the line.},
  keywords = {Communist education,Education reforms,Education systems,Human capital attainment,Labour market participation,Later life outcomes,School curriculum},
  file = {/Users/xinyiye/Zotero/storage/MTULHGDI/Costa-Font 等 - 2024 - Long-lasting effects of indoctrination in school Evidence from the People’s Republic of Poland.pdf;/Users/xinyiye/Zotero/storage/EL4M6YHE/S0014292123002696.html}
