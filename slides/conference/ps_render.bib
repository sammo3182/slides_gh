@article{PengZhengLongZhaoHongDan2011,
  title = {组织公民行为真的对组织有利吗——中国情境下的强制性公民行为研究},
  author = {{彭正龙} and {赵红丹}},
  date = {2011},
  journaltitle = {南开管理评论},
  volume = {14},
  number = {1},
  pages = {17--27},
  url = {https://kns.cnki.net/KCMS/detail/detail.aspx?dbcode=CJFQ&dbname=CJFD2011&filename=LKGP201101003},
  urldate = {2026-04-15},
  abstract = {强制性公民行为的存在及其危害已引起西方学界的高度重视,但在国内的学术期刊上还未出现相关的研究。为了探讨中国组织情境下的强制性公民行为,本文通过问卷调查和分析本土企业管理者及其直接下属的配对样本,试图揭示强制性公民行为在中国组织中的存在性、危害性及其危害路径。结果表明:(1)西方学界开发的强制性公民行为测量工具不仅适合于中国组织情境,而且表现得更为明显;(2)中国情境下,强制性公民行为与员工周边绩效和组织承诺显著负相关,但对任务绩效和角色内行为无显著影响;(3)心理契约违背在强制性公民行为与员工周边绩效的关系间发挥部分中介作用的作用;(4)中国人传统性显著调节强制性公民行为与员工周边绩效之间的关系。这些研究成果不仅为强制性公民行为理论提供了强有力的支持,还为后续研究提供了良好的研究视角和基础,对企业管理实践也具有重要的参考价值。},
  langid = {chinese},
  keywords = {工作绩效,角色内行为,强制性公民行为,组织承诺},
  annotation = {Fund: 国家社会科学基金项目(10BGL033)； 教育部博士点专项科研基金项目(20100072110010)资助；},
