@article{LiuFangShiWenJie2012,
  title = {城市基层政治参与对政治效能感的影响 一项以上海社区为例的实证研究(英文)},
  author = {{刘芳} and {施文捷}},
  date = {2012},
  journaltitle = {社会},
  volume = {32},
  number = {2},
  pages = {223--241},
  doi = {10.15992/j.cnki.31-1123/c.2012.02.004},
  url = {https://link.cnki.net/doi/10.15992/j.cnki.31-1123/c.2012.02.004},
  urldate = {2026-04-16},
  abstract = {在建设基层民主的过程中,政治效能感是反映政治体系民主和健康程度的重要指标。研究表明,特定的政治参与行为对个人政治效能感有正向或负向影响,但目前探讨中国城市基层政治参及其政治效能感的研究尚不多见。本文综合现有理论文献,将政治效能感分为内部效能感和外部效能感进行分析,并根据政治参与影响效能感的两种不同机制,将政治参与分为教育型和诱导型两类,建立多元线性回归模型进行数据分析。本研究以上海社区的抽样数据为样本,分别建立"教育型参与—内部效能感"和"诱导型参与—外部效能感"两个回归模型。前者分析"抗争"和"竞选业主委员会成员"两项教育型政治参与行为对内部政治效能感的影响;后者分析"参与居委会选举投票"和"参与业委会选举投票"两项诱导型政治参与行为对外部效能感的影响,两个模型均在一定程度上支持了本文的研究假设。但作为教育型政治参与的"抗争",因其在大部分情况下会以失败告终,故可能对政治效能感起不到一般教育型参与的促进作用。同时,通过数据分析,本文也发现"参与居委会选举投票"和"参与业委会选举投票"的差异:虽然根据已有研究两种"投票"均应归入诱导型政治参与,但是参考中国城市社区的现实情况,业委会选举机制的不成熟以及行政手段的介入,都有损于业委会选举的"政治诱导性",故可能对外部效能感产生负面作用。本文根据上述问题和本研究的不足提出了进一步的研究方向。},
  langid = {chinese},
  keywords = {城市基层社区,政治参与,政治效能感},
  annotation = {Fund: the research project “Social Change and Neighborhood Social Capital at Urban Grassroots”,which was sponsored by the China Social Science Foundation(05CSH17)；},
  file = {/Users/xinyiye/Zotero/storage/9MCXPPJX/刘芳和施文捷 - 2012 - 城市基层政治参与对政治效能感的影响 一项以上海社区为例的实证研究(英文).pdf}
}

@article{LiuLuo2023,
