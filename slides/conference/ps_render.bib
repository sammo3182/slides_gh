  shorttitle = {时间银行能否带来可持续志愿参与?},
  author = {{王焕} and {魏培晔}},
  date = {2021},
  journaltitle = {中国行政管理},
  number = {10},
  pages = {115--122},
  issn = {1006-0863},
  doi = {10.19735/j.issn.1006-0863.2021.10.14},
  url = {https://doi.org/10.19735/j.issn.1006-0863.2021.10.14},
  urldate = {2025-09-08},
  abstract = {时间银行已在全国获得了广泛实践,但鲜有实证研究讨论其对于志愿服务领域的价值。本研究以时间银行为实验干预,采用调查实验的方法对502名社会治安领域的志愿者进行实证研究。结果表明,时间银行显著提高了志愿者的可持续参与意愿。文章继续通过国内两家时间银行的案例分析得到其促进公民可持续志愿参与的内在机制,结果表明:政府给予的行政合法性增强了公众对于时间银行的信任;时间银行关于志愿服务的延期回报为志愿参与提供了长期动力;时间银行所搭建的互联网平台实现了多边供需匹配,能够提升志愿者内外部效度,进而促进志愿者的可持续志愿参与意愿。本研究从理论上拓展了志愿服务可持续性的知识积累,也为时间银行的现实实践提供了学理启示。},
  langid = {chinese},
  keywords = {调查实验,混合研究,可持续,时间银行,志愿参与,志愿服务},
