  issn = {0010-4159},
  doi = {10.5129/001041520X15810803375925},
  url = {https://www.ingentaconnect.com/content/10.5129/001041520X15810803375925},
  urldate = {2025-09-15},
  abstract = {Easton\&\#x2019;s framework for theorizing political support continues to be influential for pertinent research. However, due to the complexity of Easton\&\#x2019;s arguments, there is some confusion on how to classify and measure political support in existing research. Building upon Easton\&\#x2019;s arguments, we propose a two-dimensional cognitive framework to examine political support, which not only adequately captures Easton\&\#x2019;s essential arguments but also effectively incorporates recent findings in cognitive psychology. Using the framework and multiple national surveys, we assess different instruments widely used to measure regime support in China. We clarify some confusion in the operationalization of political support, establish the salience of institutional settings in shaping its latent structure, assess key survey instruments of regime support, and offer guidelines on how to appropriately interpret related findings.},
  file = {/Users/xinyiye/Zotero/storage/DQRSSJHE/Lu和Dickson - 2020 - Revisiting the Eastonian Framework on Political Support Assessing Different Measures of Regime Supp.pdf}
}

